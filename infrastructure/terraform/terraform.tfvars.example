# EduNexus Terraform Variables
# Copy this file to terraform.tfvars and update values

# AWS Region
aws_region = "ap-south-1"

# Project Configuration
project_name = "edunexus"
environment  = "demo"

# EC2 Configuration
ec2_instance_type = "t3.small"  # ~$15/month
ec2_volume_size   = 20          # GB

# RDS Configuration (Free Tier)
db_instance_class    = "db.t3.micro"  # Free Tier eligible
db_allocated_storage = 20              # GB (Free Tier: 20GB included)
db_name              = "edunexus"
db_username          = "edunexus"

# Security - IMPORTANT: Change this to your IP!
# Find your IP: curl ifconfig.me
allowed_ssh_cidr = "0.0.0.0/0"  # Change to "YOUR_IP/32" for security

# Domain (optional)
domain_name = ""  # e.g., "demo.edunexus.io"

# Tags
tags = {
  Project     = "EduNexus"
  Environment = "demo"
  ManagedBy   = "Terraform"
}
