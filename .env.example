# EduNexus Environment Variables
# Copy this file to .env and fill in your values

# ===========================================
# DATABASE
# ===========================================
DATABASE_URL="postgresql://edunexus:edunexus_dev_password@localhost:5432/edunexus?schema=public"

# ===========================================
# REDIS
# ===========================================
REDIS_URL="redis://localhost:6379"

# ===========================================
# AUTHENTICATION (Clerk)
# ===========================================
# Get these from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# Clerk URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# ===========================================
# VECTOR DATABASE (Qdrant)
# ===========================================
QDRANT_URL="http://localhost:6333"

# ===========================================
# AI SERVICES
# ===========================================
# OpenAI (for GPT models)
OPENAI_API_KEY=sk-xxx

# Anthropic (for Claude)
ANTHROPIC_API_KEY=sk-ant-xxx

# ML Service URL
ML_SERVICE_URL="http://localhost:8000"

# ===========================================
# PAYMENT (Stripe)
# ===========================================
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# ===========================================
# EMAIL (SendGrid)
# ===========================================
SENDGRID_API_KEY=SG.xxx
SENDGRID_FROM_EMAIL=noreply@edunexus.com

# ===========================================
# SMS (MSG91)
# ===========================================
MSG91_AUTH_KEY=xxx
MSG91_SENDER_ID=EDUNEX

# ===========================================
# STORAGE (AWS S3)
# ===========================================
AWS_ACCESS_KEY_ID=xxx
AWS_SECRET_ACCESS_KEY=xxx
AWS_REGION=ap-south-1
AWS_S3_BUCKET=edunexus-uploads

# ===========================================
# APP CONFIG
# ===========================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
API_URL=http://localhost:3001
NODE_ENV=development
