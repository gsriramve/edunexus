# ============================================================================
# EduNexus Environment Variables
# ============================================================================
# Copy this file to .env and fill in your values
# For local development, also copy relevant vars to:
#   - apps/api/.env
#   - apps/web/.env.local
# ============================================================================

# ===========================================
# ENVIRONMENT
# ===========================================
NODE_ENV=development
# Options: development, staging, production

# ===========================================
# DATABASE (PostgreSQL)
# ===========================================
# Local Development (Docker)
DATABASE_URL="postgresql://edunexus:edunexus_dev_password@localhost:5432/edunexus?schema=public"

# Staging (AWS RDS)
# DATABASE_URL="postgresql://edunexus:${DB_PASSWORD}@edunexus-staging.xxxxx.ap-south-1.rds.amazonaws.com:5432/edunexus?schema=public&connection_limit=10"

# Production (AWS RDS with PgBouncer)
# DATABASE_URL="postgresql://edunexus:${DB_PASSWORD}@edunexus-proxy.proxy-xxxxx.ap-south-1.rds.amazonaws.com:5432/edunexus?schema=public&pgbouncer=true&connection_limit=20"

# Direct URL for migrations (bypasses connection pooler)
# DIRECT_URL="postgresql://edunexus:${DB_PASSWORD}@edunexus-rds.xxxxx.ap-south-1.rds.amazonaws.com:5432/edunexus"

# ===========================================
# REDIS (Caching & Queues)
# ===========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL="redis://localhost:6379"
# REDIS_PASSWORD=

# Production (ElastiCache)
# REDIS_HOST=edunexus-redis.xxxxx.ap-south-1.cache.amazonaws.com

# ===========================================
# API SERVER
# ===========================================
PORT=3001
# API_HOST=0.0.0.0

# ===========================================
# AUTHENTICATION (Clerk)
# ===========================================
# Get these from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# Clerk URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ===========================================
# PAYMENT (Razorpay)
# ===========================================
# Get these from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_xxx
RAZORPAY_KEY_SECRET=xxx
RAZORPAY_WEBHOOK_SECRET=xxx
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxx

# ===========================================
# EMAIL (SendGrid)
# ===========================================
# Get this from https://app.sendgrid.com
SENDGRID_API_KEY=SG.xxx
SENDGRID_FROM_EMAIL=noreply@edunexus.io
SENDGRID_FROM_NAME=EduNexus

# ===========================================
# SMS (MSG91)
# ===========================================
# Get these from https://msg91.com
MSG91_AUTH_KEY=xxx
MSG91_SENDER_ID=EDUNXS
MSG91_ROUTE=4
MSG91_DLT_TE_ID=xxx

# ===========================================
# PUSH NOTIFICATIONS (Firebase)
# ===========================================
# Get these from: Firebase Console > Project Settings > Service Accounts
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ===========================================
# STORAGE (AWS S3)
# ===========================================
AWS_ACCESS_KEY_ID=xxx
AWS_SECRET_ACCESS_KEY=xxx
AWS_REGION=ap-south-1
AWS_S3_BUCKET=edunexus-uploads

# ===========================================
# AI SERVICES
# ===========================================
# OpenAI (for GPT models)
OPENAI_API_KEY=sk-xxx

# Anthropic (for Claude)
ANTHROPIC_API_KEY=sk-ant-xxx

# ML Service URL
ML_SERVICE_URL="http://localhost:8000"

# Vector Database (Qdrant)
QDRANT_URL="http://localhost:6333"

# ===========================================
# APP CONFIG
# ===========================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001
API_URL=http://localhost:3001

# ===========================================
# MONITORING (Optional)
# ===========================================
# SENTRY_DSN=
# DATADOG_API_KEY=

# ===========================================
# TURBOREPO (Optional)
# ===========================================
# TURBO_TOKEN=
# TURBO_TEAM=
