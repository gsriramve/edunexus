// =============================================================================
// ALUMNI MANAGEMENT
// =============================================================================

/// Alumni Profile - Graduated student profiles
model AlumniProfile {
  id        String  @id @default(cuid())
  tenantId  String
  studentId String? @unique // Link to original student record
  userId    String? @unique // User account for alumni login

  // Personal info
  firstName   String
  lastName    String
  email       String
  phone       String?
  photoUrl    String?
  linkedinUrl String?
  twitterUrl  String?
  websiteUrl  String?

  // Academic info
  graduationYear Int
  batch          String // e.g., "2021-2025"
  departmentId   String?
  degree         String? // e.g., "B.Tech Computer Science"
  finalCgpa      Float?

  // Registration
  registrationStatus String    @default("pending") // pending, approved, rejected
  registrationDate   DateTime?
  approvedBy         String?

  // Current status
  currentStatus String @default("employed") // employed, entrepreneur, higher_studies, unemployed, other

  // Profile visibility
  visibleInDirectory Boolean @default(true)
  showEmail          Boolean @default(false)
  showPhone          Boolean @default(false)
  showEmployment     Boolean @default(true)

  // Mentorship
  openToMentoring Boolean @default(false)
  mentorshipAreas String[] @default([]) // Areas willing to mentor

  // Bio
  bio          String? @db.Text
  achievements String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student    Student?    @relation(fields: [studentId], references: [id])
  department Department? @relation(fields: [departmentId], references: [id])

  employmentHistory AlumniEmployment[]
  mentorships       AlumniMentorship[] @relation("AlumniMentor")
  contributions     AlumniContribution[]
  testimonials      AlumniTestimonial[]
  eventAttendances  AlumniEventAttendance[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([graduationYear])
  @@index([departmentId])
  @@index([currentStatus])
  @@map("alumni_profiles")
}

/// Alumni Employment - Work history
model AlumniEmployment {
  id       String @id @default(cuid())
  tenantId String
  alumniId String

  companyName String
  role        String
  location    String?

  startDate DateTime
  endDate   DateTime?
  isCurrent Boolean   @default(true)

  salaryBand  String? // Not displayed publicly
  industry    String?
  companySize String? // startup, small, medium, large, enterprise

  description String? @db.Text

  isVerified Boolean   @default(false) // Admin verified
  verifiedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  alumni AlumniProfile @relation(fields: [alumniId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([alumniId])
  @@index([companyName])
  @@index([isCurrent])
  @@map("alumni_employment")
}

/// Alumni Mentorship - Mentor-mentee relationships
model AlumniMentorship {
  id        String @id @default(cuid())
  tenantId  String
  alumniId  String
  studentId String

  focusArea String // career_guidance, technical, interview_prep, etc.
  status    String @default("pending") // pending, active, completed, cancelled

  // Request details
  requestMessage String? @db.Text
  responseMessage String? @db.Text

  startDate     DateTime?
  endDate       DateTime?
  meetingsCount Int       @default(0)

  // Ratings
  studentRating  Int? // 1-5
  studentReview  String?
  alumniRating   Int? // 1-5
  alumniReview   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  alumni  AlumniProfile @relation("AlumniMentor", fields: [alumniId], references: [id], onDelete: Cascade)
  student Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([alumniId, studentId])
  @@index([tenantId])
  @@index([alumniId])
  @@index([studentId])
  @@index([status])
  @@map("alumni_mentorships")
}

/// Alumni Contribution - Donations and contributions
model AlumniContribution {
  id       String @id @default(cuid())
  tenantId String
  alumniId String

  contributionType String // monetary, scholarship, equipment, time, guest_lecture
  title            String
  description      String? @db.Text

  // For monetary
  amount   Decimal? @db.Decimal(12, 2)
  currency String   @default("INR")

  // For non-monetary
  estimatedValue Decimal? @db.Decimal(12, 2)
  hoursContributed Int?

  // Allocation
  allocatedTo     String? // scholarship_fund, department, infrastructure, etc.
  beneficiaryInfo String?

  // Status
  status       String    @default("pending") // pending, approved, received, acknowledged
  receivedDate DateTime?
  acknowledgedBy String?

  // Recognition
  isPubliclyAcknowledged Boolean @default(true)
  acknowledgementText    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  alumni AlumniProfile @relation(fields: [alumniId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([alumniId])
  @@index([contributionType])
  @@index([status])
  @@map("alumni_contributions")
}

/// Alumni Testimonial - Success stories
model AlumniTestimonial {
  id       String @id @default(cuid())
  tenantId String
  alumniId String

  title    String
  content  String  @db.Text
  videoUrl String?
  imageUrl String?
  category String // career_success, entrepreneurship, higher_studies, gratitude

  // Approval
  isApproved Boolean   @default(false)
  approvedBy String?
  approvedAt DateTime?

  // Display
  isFeatured   Boolean @default(false)
  displayOrder Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  alumni AlumniProfile @relation(fields: [alumniId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([alumniId])
  @@index([isApproved])
  @@index([isFeatured])
  @@map("alumni_testimonials")
}

/// Alumni Event - Reunions, networking events
model AlumniEvent {
  id       String @id @default(cuid())
  tenantId String

  title       String
  description String? @db.Text
  eventType   String // reunion, networking, guest_lecture, workshop, homecoming

  startDate DateTime
  endDate   DateTime?
  venue     String?
  isVirtual Boolean  @default(false)
  meetLink  String?

  // Registration
  registrationDeadline DateTime?
  maxAttendees         Int?
  registrationFee      Decimal?  @db.Decimal(8, 2)

  // Target audience
  targetBatches   String[] @default([]) // Empty = all batches
  targetDepartments String[] @default([]) // Empty = all departments

  // Status
  status String @default("draft") // draft, published, ongoing, completed, cancelled

  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

