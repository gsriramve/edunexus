// =============================================================================
// ACCREDITATION MANAGEMENT (NBA, NAAC, NIRF)
// =============================================================================

/// Accreditation Metric - Criteria definitions
model AccreditationMetric {
  id       String @id @default(cuid())
  tenantId String

  framework     String // NBA, NAAC, NIRF
  criterionCode String // e.g., "1.1.1", "C1", "TLR"
  criterionName String
  category      String // e.g., "Teaching-Learning", "Research", "Infrastructure"

  description String? @db.Text
  maxScore    Float
  weightage   Float   @default(1) // Weight in overall score

  // Data source mapping
  dataSource     String? // Which table/field to pull data from
  calculationFormula String? @db.Text // Formula for calculation
  mappedEntities Json? // [{entity, field, aggregation}]

  // Benchmarks
  minThreshold Float? // Minimum acceptable value
  maxThreshold Float? // Maximum/target value

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  values AccreditationValue[]

  @@unique([tenantId, framework, criterionCode])
  @@index([tenantId])
  @@index([framework])
  @@index([category])
  @@map("accreditation_metrics")
}

/// Accreditation Value - Actual metric values
model AccreditationValue {
  id       String @id @default(cuid())
  tenantId String
  metricId String

  academicYear String // e.g., "2024-25"

  // Values
  rawValue        Float? // Original calculated value
  normalizedValue Float? // Normalized to 0-100
  score           Float? // Final score (after weightage)

  // Supporting data
  supportingData Json? // Evidence/source data
  remarks        String?

  // Trend
  previousValue Float?
  trend         String? // improving, stable, declining

  // Audit
  calculatedAt   DateTime?
  verifiedBy     String?
  verifiedAt     DateTime?
  isLatest       Boolean   @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  metric AccreditationMetric @relation(fields: [metricId], references: [id], onDelete: Cascade)

  @@unique([metricId, academicYear])
  @@index([tenantId])
  @@index([metricId])
  @@index([academicYear])
  @@index([isLatest])
  @@map("accreditation_values")
}

/// Accreditation Report - Generated reports for submission
model AccreditationReport {
  id       String @id @default(cuid())
  tenantId String

  framework    String // NBA, NAAC, NIRF
  academicYear String
  title        String
  description  String?

  // Scores
  totalScore    Float?
  maxScore      Float?
  percentage    Float?
  grade         String? // A++, A+, A, B++, etc. for NAAC

  // Report file
  reportUrl    String?
  reportS3Key  String?
  generatedAt  DateTime?

  // Status
  status      String @default("draft") // draft, in_progress, review, submitted, approved
  submittedAt DateTime?
  submittedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, framework, academicYear])
  @@index([tenantId])
  @@index([framework])
  @@index([status])
  @@map("accreditation_reports")
}

// =============================================================================
// DIRECT MESSAGING SYSTEM
// =============================================================================

/// Direct messages between users (teachers, students, parents, staff)
model DirectMessage {
  id       String @id @default(cuid())
  tenantId String

  // Sender information
  senderId     String
  senderType   String // teacher, student, parent, staff, hod, principal
  senderName   String

  // Recipient information (individual or group)
  recipientType    String // individual, class, department, custom
  recipientId      String? // User ID for individual, class/department ID for groups
  recipientName    String? // Display name for recipient
  recipientUserType String? // student, parent, teacher, staff (for individual)

  // For group messages - store recipient list
  recipientIds Json? // Array of {id, name, type} for custom groups

  // Message content
  subject     String
  content     String   @db.Text
  messageType String   @default("general") // general, query, request, announcement, reply

  // Parent message for threads/replies
  parentId    String?
  threadId    String? // Root message ID for conversation threads

  // Attachments
  attachments Json? // Array of {name, url, type, size}

  // Status tracking
  status      String    @default("sent") // draft, sent, delivered, read
  isRead      Boolean   @default(false)
  readAt      DateTime?
  isStarred   Boolean   @default(false)
  isArchived  Boolean   @default(false)
  isDeleted   Boolean   @default(false) // Soft delete
  deletedAt   DateTime?

  // For sent messages - track delivery
  deliveredCount Int @default(0)
  readCount      Int @default(0)
  totalRecipients Int @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parent   DirectMessage?  @relation("MessageThread", fields: [parentId], references: [id])
  replies  DirectMessage[] @relation("MessageThread")
  receipts MessageReceipt[]

  @@index([tenantId])
  @@index([senderId])
  @@index([recipientId])
  @@index([recipientType])
  @@index([threadId])
  @@index([parentId])
  @@index([status])
  @@index([isRead])
  @@index([isArchived])
  @@index([createdAt])
  @@map("direct_messages")
}

/// Message receipts for tracking delivery and read status per recipient
model MessageReceipt {
  id        String @id @default(cuid())
  tenantId  String
  messageId String

  // Recipient info
  recipientId   String
  recipientType String // student, parent, teacher, staff
  recipientName String

  // Status
  deliveredAt DateTime?
  readAt      DateTime?
  isStarred   Boolean   @default(false)
  isArchived  Boolean   @default(false)
  isDeleted   Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  message DirectMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, recipientId])
  @@index([tenantId])
  @@index([messageId])
  @@index([recipientId])
  @@index([readAt])
  @@map("message_receipts")
}
