/// Student Goals - Personal goals tracking
model StudentGoal {
  id        String @id @default(cuid())
  tenantId  String
  studentId String

  title       String
  description String? @db.Text
  category    String // academic, career, skill, extracurricular, personal

  // Target metrics
  targetDate  DateTime?
  targetValue Float?
  currentValue Float?
  unit        String? // e.g., "CGPA", "certifications", "%"

  // Goal source
  isAiSuggested    Boolean @default(false)
  isMentorAssigned Boolean @default(false)
  assignedBy       String? // User ID if assigned by mentor

  // Progress tracking
  status   String @default("active") // active, completed, abandoned, overdue
  progress Float  @default(0) // 0-100

  // Milestones
  milestones Json? // [{title, targetDate, completed, completedAt}]

  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([studentId])
  @@index([status])
  @@index([category])
  @@map("student_goals")
}

/// Disengagement Alert - Early warning system
model DisengagementAlert {
  id        String @id @default(cuid())
  tenantId  String
  studentId String

  alertType String // attendance_drop, grade_decline, activity_drop, feedback_concern
  severity  String @default("warning") // info, warning, critical

  // Metric details
  metricName    String // e.g., "attendance_rate", "cgpa", "club_activity"
  currentValue  Float
  previousValue Float?
  thresholdValue Float
  changePercent Float?

  // Context
  timeframe   String? // e.g., "last 30 days"
  description String? @db.Text
  suggestedActions Json? // [{action, priority, assignedTo}]

  // Resolution tracking
  status         String    @default("new") // new, acknowledged, in_progress, resolved, false_positive
  acknowledgedBy String? // User ID
  acknowledgedAt DateTime?
  resolvedBy     String?
  resolvedAt     DateTime?
  resolution     String? // How it was resolved

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([studentId])
  @@index([status])
  @@index([severity])
  @@index([alertType])
  @@map("disengagement_alerts")
}

// =============================================================================
// STUDENT JOURNEY TIMELINE
